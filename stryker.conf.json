{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "vitest": {
    "configFile": "vitest.config.stryker.ts"
  },
  "mutate": [
    "src/main/services/result-service.ts",
    "src/main/services/chronology-guard.ts",
    "src/main/services/vat-report-service.ts",
    "src/main/services/correction-service.ts",
    "src/main/services/depreciation-service.ts",
    "src/main/services/bank/bank-fee-classifier.ts",
    "src/main/services/bank/iban-bank-registry.ts",
    "src/shared/money.ts",
    "src/shared/parse-decimal.ts"
  ],
  "ignorePatterns": [
    "release",
    "dist",
    "dist-main",
    "dist-preload",
    "dist-renderer",
    "coverage",
    "reports",
    ".stryker-tmp",
    "node_modules/.cache",
    "playwright-report",
    "test-results",
    "e2e-user-data"
  ],
  "checkers": [],
  "timeoutMS": 30000,
  "concurrency": 4,
  "thresholds": { "high": 95, "low": 80, "break": 70 },
  "reporters": ["clear-text", "html", "json"],
  "htmlReporter": { "fileName": "reports/mutation/index.html" },
  "jsonReporter": { "fileName": "reports/mutation/mutation-report.json" },
  "logLevel": "info"
}
