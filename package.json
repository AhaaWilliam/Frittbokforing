{
  "name": "fritt-bokforing",
  "version": "0.1.0",
  "description": "Fritt Bokföring — lokal bokföringsapp för svenska företag",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && npm run build:main && electron-rebuild -f -w better-sqlite3 && NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "predist": "npm run build",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "publish:github": "electron-builder --mac --publish always",
    "test": "npm rebuild better-sqlite3 && vitest run",
    "test:watch": "vitest",
    "test:system": "vitest run tests/system/",
    "test:security": "vitest run tests/security/",
    "test:e2e": "electron-rebuild -f -w better-sqlite3 && playwright test",
    "test:e2e:headed": "electron-rebuild -f -w better-sqlite3 && playwright test --headed",
    "test:e2e:ci": "xvfb-run --auto-servernum --server-args='-screen 0 1280x960x24' npx playwright test --config=e2e/playwright.config.ts",
    "test:all": "vitest run && npx playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'tests/**/*.ts'",
    "dump:source": "node scripts/dump-source.mjs",
    "check:m131": "bash scripts/m131-check.sh",
    "check:m133": "node scripts/check-m133.mjs"
  },
  "keywords": [
    "bokföring",
    "accounting",
    "electron",
    "sqlite"
  ],
  "author": "William Nordström",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^1.7.0",
    "pdfkit": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.1",
    "sonner": "^2.0.7",
    "xmlbuilder2": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.3",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.1",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "se.nordstrom.fritt-bokforing",
    "productName": "Fritt Bokföring",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "icon": "build/icon.png",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": false
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Finance"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "OWNER",
      "repo": "fritt-bokforing"
    }
  }
}
